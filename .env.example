# ══════════════════════════════════════════════════════════════════
# .env.example — Variables de entorno para Dalux Agency
# ══════════════════════════════════════════════════════════════════
# Copia este archivo a ".env" y rellena tus credenciales reales.
# NUNCA subas el archivo .env a Git.
# ══════════════════════════════════════════════════════════════════

# ── Claude API ──────────────────────────────────────────────────
# Obtén tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Servidor ────────────────────────────────────────────────────
PORT=3000

# ID del negocio activo (debe coincidir con el nombre del archivo
# en config/businesses/ sin la extensión .json)
BUSINESS_ID=spa-example

# ── Twilio (WhatsApp Sandbox para demo) ─────────────────────────
# Crea una cuenta en https://www.twilio.com
# Activa el Sandbox en: Console > Messaging > Try it out > WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── WhatsApp Cloud API (producción — Meta) ───────────────────────
# Configurar cuando migres de Twilio a Meta Cloud API
# Guía: https://developers.facebook.com/docs/whatsapp/cloud-api
META_VERIFY_TOKEN=tu_token_de_verificacion_personalizado
META_WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxx
META_PHONE_NUMBER_ID=1234567890

# ── Instagram Messaging API ──────────────────────────────────────
# Usa el mismo App de Facebook que WhatsApp Cloud API
META_INSTAGRAM_TOKEN=EAAxxxxxxxxxxxxxx
META_INSTAGRAM_PAGE_ID=1234567890

# ── Google Calendar (Ruta B — solo negocios con Gmail) ───────────
# Sigue la guía del README para obtener estas credenciales:
# https://console.cloud.google.com/ > APIs > Google Calendar API
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob

# Tokens por negocio — el sufijo es el ID del negocio en MAYÚSCULAS
# con guiones reemplazados por guiones bajos
# Ejemplo para businessId "dentista-guerrero":
GOOGLE_ACCESS_TOKEN_DENTISTA_GUERRERO=ya29.xxxxxxxxxxxx
GOOGLE_REFRESH_TOKEN_DENTISTA_GUERRERO=1//xxxxxxxxxxxx

# Ejemplo para businessId "spa-zenith":
# GOOGLE_ACCESS_TOKEN_SPA_ZENITH=ya29.xxxxxxxxxxxx
# GOOGLE_REFRESH_TOKEN_SPA_ZENITH=1//xxxxxxxxxxxx

# ── Make.com (opcional — orquestación de webhooks) ───────────────
# URL del webhook de Make.com para disparar escenarios adicionales
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/xxxxxxxxxxxxxxxx
